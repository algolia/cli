# Dry-run paths for `agents create / update / delete / run` are
# exhaustively unit-tested already; this script is the contract test
# that proves the same shape holds when wired through the full cobra
# tree under the e2e binary. None of these commands hit the network —
# `--dry-run` short-circuits before client construction.
#
# `agents try` does NOT have a `--dry-run` flag — the whole command is
# the dry-run in the conversational-ai sense (unsaved-config completion
# via the agent_id="test" route). See AGENTS.md → "On `--dry-run`".
#
# Ungated: runs whenever the standard ALGOLIA_APPLICATION_ID +
# ALGOLIA_API_KEY are present (same as the rest of the e2e suite).

# ---------------------------------------------------------------------
# create --dry-run with --output json emits the structured envelope
# ---------------------------------------------------------------------
exec algolia agents create -F cfg.json --dry-run --output json
! stderr .
stdout -count=1 '"action":"create_agent"'
stdout -count=1 '"request":"POST /1/agents"'
stdout -count=1 '"dryRun":true'

# ---------------------------------------------------------------------
# create --dry-run human mode shows the resolved body verbatim
# (this is the default; ANY output without --output should preview
# the body — that's the whole point of the human dry-run)
# ---------------------------------------------------------------------
exec algolia agents create -F cfg.json --dry-run
! stderr .
stdout -count=1 'Dry run: would POST /1/agents'
stdout -count=1 '"name": "e2e-create-stub"'

# ---------------------------------------------------------------------
# update --dry-run includes the agent id in the path
# ---------------------------------------------------------------------
exec algolia agents update 00000000-0000-0000-0000-000000000001 -F patch.json --dry-run
! stderr .
stdout -count=1 'Dry run: would PATCH /1/agents/00000000-0000-0000-0000-000000000001'
stdout -count=1 '"name": "e2e-update-stub"'

# ---------------------------------------------------------------------
# run <id> --dry-run includes the id in the path and does NOT include
# a `configuration` field (only `agents try` sends configuration —
# `agents run` uses the persisted agent's config)
# ---------------------------------------------------------------------
exec algolia agents run 11111111-1111-1111-1111-111111111111 -m hi --dry-run
! stderr .
stdout -count=1 'Dry run: would POST /1/agents/11111111-1111-1111-1111-111111111111/completions'
stdout -count=1 '"messages"'
! stdout 'configuration'

# ---------------------------------------------------------------------
# `agents try` has no --dry-run flag (the whole command is the
# dry-run). Confirm the flag is rejected so a future regression that
# re-adds it is caught.
# ---------------------------------------------------------------------
! exec algolia agents try -c cfg.json -m hi --dry-run
stderr 'unknown flag'

# ---------------------------------------------------------------------
# Completion runtime flags wire into the dry-run preview body
# without changing it (they're query params + a header, not body
# fields). Same for `agents try` which does NOT echo them via
# --dry-run because it has no --dry-run. The body preview must remain
# stable across these flag combos so users can diff configs cleanly.
# ---------------------------------------------------------------------
exec algolia agents run 11111111-1111-1111-1111-111111111111 -m hi --no-cache --no-memory --no-analytics --secure-user-token ey.signed.jwt --dry-run
! stderr .
stdout -count=1 'Dry run: would POST /1/agents/11111111-1111-1111-1111-111111111111/completions'
stdout -count=1 '"content": "hi"'
# completion-runtime knobs are wire-only; never in the body
! stdout '"cache"'
! stdout '"memory"'
! stdout '"analytics"'
! stdout 'secure-user-token'

-- cfg.json --
{"name":"e2e-create-stub","instructions":"e2e","widgetType":"filterSuggestions","enableAlgoliaMcp":false}

-- patch.json --
{"name":"e2e-update-stub","instructions":"e2e patched"}
