# `agents user-data` — flag-validation + dry-run contract.

exec algolia agents user-data
stdout 'get'
stdout 'delete'

! exec algolia agents user-data get
stderr 'requires exactly 1 argument'

! exec algolia agents user-data delete tok1
stderr '--confirm required'

exec algolia agents user-data delete tok1 --dry-run
! stderr .
stdout 'Dry run: would DELETE /1/user-data/tok1'

exec algolia agents userdata delete tok1 --dry-run
! stderr .
stdout 'Dry run: would DELETE /1/user-data/tok1'
